{
  "name": "enterprise-cicd-agents",
  "version": "1.0.0",
  "description": "Enterprise CI/CD Governance powered by GitHub Copilot SDK - AI-driven PR analysis, security scanning, and deployment decisions",
  "main": "dist/index.js",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/server/index.js",
    "dev": "npx tsx src/server/index.ts",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --passWithNoTests",
    "test:ci": "npm test -- --json --outputFile=test-results.json",
    "lint": "eslint . --ext .ts --max-warnings 0",
    "lint:fix": "eslint . --ext .ts --fix",
    "mcp:start": "npx tsx src/mcp/server.ts",
    "ci:local": "npm run build && npm test && npm run lint",
    "clean": "rimraf dist coverage test-results.json"
  },
  "keywords": [
    "cicd",
    "agents",
    "github-actions",
    "enterprise",
    "devops",
    "copilot-sdk",
    "mcp",
    "ai-governance"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@github/copilot-sdk": "^0.1.30",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@octokit/rest": "^20.0.2",
    "@opentelemetry/api": "^1.7.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.48.0",
    "@opentelemetry/sdk-node": "^0.48.0",
    "@opentelemetry/sdk-trace-base": "^1.22.0",
    "@azure/identity": "^4.0.0",
    "@azure/monitor-query": "^1.2.0",
    "axios": "^1.6.0",
    "express": "^4.18.2",
    "yaml": "^2.3.4",
    "zod": "^3.25.76"
  }
}
